# ═══════════════════════════════════════════════════════════════
# Necoll — Environment Variables
# کپی کنید: cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ─── عمومی ───────────────────────────────────────────────────
NODE_ENV=production
HOST=0.0.0.0
NGINX_PORT=3011

# ─── آدرس‌های عمومی سایت (مرورگر کاربر) ─────────────────────
# این مقادیر هنگام docker build در store/admin استفاده می‌شوند.
# محلی:
SITE_URL=http://localhost:3011
CORS_ORIGIN=http://localhost:3011
NEXT_PUBLIC_SITE_URL=http://localhost:3011
NEXT_PUBLIC_API_URL=http://localhost:3011/api

# سرور (نمونه — مقادیر را با دامنه واقعی جایگزین کنید):
# SITE_URL=https://necoll.ir
# CORS_ORIGIN=https://necoll.ir
# NEXT_PUBLIC_SITE_URL=https://necoll.ir
# NEXT_PUBLIC_API_URL=https://necoll.ir/api

# ─── ارتباط داخلی بین کانتینرها (تغییر ندهید) ───────────────
API_INTERNAL_URL=http://backend:4000/api
BACKEND_PORT=4000
REDIS_URL=redis://redis:6379

# ─── PostgreSQL ────────────────────────────────────────────────
POSTGRES_USER=necoll
POSTGRES_PASSWORD=necoll_secret
POSTGRES_DB=necoll_db

# ─── امنیت ───────────────────────────────────────────────────
JWT_SECRET=necoll_jwt_super_secret_change_in_production

# ─── MinIO (ذخیره‌سازی فایل) ─────────────────────────────────
MINIO_ROOT_USER=necoll_minio
MINIO_ROOT_PASSWORD=necoll_minio_secret
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_BUCKET=necoll-uploads
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_PUBLIC_URL=http://localhost:9000

# ─── Prisma (اختیاری — آینه دانلود در ایران) ────────────────
PRISMA_ENGINES_MIRROR=https://registry.npmmirror.com/-/binary/prisma

# ─── توسعه محلی (اختیاری) ───────────────────────────────────
# برای hot-reload و Adminer از override استفاده کنید:
# COMPOSE_FILE=docker-compose.yml:docker-compose.dev.yml
# NODE_ENV=development
# ADMINER_PORT=8080
# WATCHPACK_POLLING=true
# CHOKIDAR_USEPOLLING=true
