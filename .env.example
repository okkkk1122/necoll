# --- تنظیمات شما (Dokploy > Project > Environment) ---
# (در صورت نیاز SMTP، درگاه پرداخت و ... اینجا اضافه کنید)

# --- سرور ---
NODE_ENV=production
DOMAIN=necoll.ir
HOST=0.0.0.0
BACKEND_PORT=4000

DB_USER=necoll
DB_PASSWORD=CHANGE_ME
DB_NAME=necoll_db
DATABASE_URL=postgresql://necoll:CHANGE_ME@postgres:5432/necoll_db

SITE_URL=https://necoll.ir
CORS_ORIGIN=https://necoll.ir
NEXT_PUBLIC_SITE_URL=https://necoll.ir
NEXT_PUBLIC_API_URL=https://necoll.ir/api
API_INTERNAL_URL=http://backend:4000/api

REDIS_URL=redis://redis:6379
JWT_SECRET=CHANGE_ME_MIN_32_CHARS

MINIO_ROOT_USER=necoll_minio
MINIO_ROOT_PASSWORD=CHANGE_ME
MINIO_ENDPOINT=minio
MINIO_PORT=9000
MINIO_BUCKET=necoll-uploads
MINIO_PUBLIC_URL=https://necoll.ir/uploads
