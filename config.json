{
  "project": {
    "name": "necoll",
    "domain": "necoll.ir",
    "repo": "https://github.com/okkkk1122/necoll.git",
    "db_password": "necoll_secret",
    "ssl": true
  },
  "services": {
    "web": {
      "container": "nginx",
      "port": 80
    },
    "api": {
      "container": "backend",
      "port": 4000
    },
    "admin": {
      "container": "admin",
      "port": 3000
    }
  },
  "other_services": [
    { "container": "postgres", "port": 5432 },
    { "container": "redis", "port": 6379 },
    { "container": "minio", "port": 9000 },
    { "container": "store", "port": 3000 }
  ],
  "extra_env": {
    "NODE_ENV": "production",
    "SITE_PORT": "80",
    "DB_USER": "necoll",
    "DB_NAME": "necoll_db",
    "JWT_SECRET": "necoll_jwt_super_secret_change_in_production",
    "MINIO_ROOT_USER": "necoll_minio",
    "MINIO_ROOT_PASSWORD": "necoll_minio_secret",
    "MINIO_BUCKET": "necoll-uploads",
    "SITE_URL": "https://necoll.ir",
    "CORS_ORIGIN": "https://necoll.ir",
    "NEXT_PUBLIC_SITE_URL": "https://necoll.ir",
    "NEXT_PUBLIC_API_URL": "https://necoll.ir/api",
    "MINIO_PUBLIC_URL": "https://necoll.ir/uploads"
  },
  "extra_routes": {
    "/api/": "backend:4000",
    "/uploads/": "minio:9000",
    "/_next/": "store:3000",
    "/admin/": "admin:3000",
    "/": "store:3000"
  },
  "extra_ports": ["80:80"],
  "notes": "استقرار: cp .env.example .env → مقادیر extra_env را در .env تنظیم کنید → docker compose build --no-cache store admin backend → docker compose up -d. نقطه ورود عمومی nginx است (پورت 80). فروشگاه (store) و پنل (admin) هر دو پورت داخلی 3000 دارند؛ مسیر /_next/ حتماً به store برود. Adminer (8080) فقط در docker-compose.dev.yml برای توسعه است. نمونه Nginx بیرونی: nginx/host-reverse-proxy.example.conf"
}
