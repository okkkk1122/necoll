generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ═══════════════════════════════════════════════════════════
// HyperConfig System - Three Layer Configuration
// ═══════════════════════════════════════════════════════════

enum ConfigLayer {
  SYSTEM
  MODULE
  COMPONENT
}

enum ConfigCategory {
  GENERAL
  APPEARANCE
  PRODUCT
  NAVIGATION
  PAYMENT
  SOCIAL
  SEO
  NOTIFICATION
  INTEGRATION
  BUSINESS_RULE
  LAYOUT
  MODULE
  SUPPORT
}

model Setting {
  id              String         @id @default(uuid())
  key             String         @unique
  value           Json
  defaultValue    Json           @map("default_value")
  category        ConfigCategory
  layer           ConfigLayer    @default(COMPONENT)
  label           String?
  description     String?
  isActive        Boolean        @default(true) @map("is_active")
  editableByAdmin Boolean        @default(true) @map("editable_by_admin")
  deletable       Boolean        @default(true)
  sortOrder       Int            @default(0) @map("sort_order")
  conditions      Json?
  metadata        Json?
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")

  sandboxOverrides SandboxOverride[]

  @@index([category])
  @@index([layer])
  @@map("settings")
}

model SandboxSession {
  id          String            @id @default(uuid())
  name        String
  isActive    Boolean           @default(true) @map("is_active")
  createdBy   String            @map("created_by")
  createdAt   DateTime          @default(now()) @map("created_at")
  expiresAt   DateTime?         @map("expires_at")
  overrides   SandboxOverride[]

  @@map("sandbox_sessions")
}

model SandboxOverride {
  id               String         @id @default(uuid())
  sandboxSessionId String         @map("sandbox_session_id")
  settingId        String         @map("setting_id")
  value            Json
  createdAt        DateTime       @default(now()) @map("created_at")

  sandboxSession   SandboxSession @relation(fields: [sandboxSessionId], references: [id], onDelete: Cascade)
  setting          Setting        @relation(fields: [settingId], references: [id], onDelete: Cascade)

  @@unique([sandboxSessionId, settingId])
  @@map("sandbox_overrides")
}

// ═══════════════════════════════════════════════════════════
// Module System
// ═══════════════════════════════════════════════════════════

model Module {
  id          String   @id @default(uuid())
  slug        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  config      Json     @default("{}")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  components  Component[]

  @@map("modules")
}

model Component {
  id          String   @id @default(uuid())
  moduleId    String   @map("module_id")
  slug        String
  name        String
  type        String
  isActive    Boolean  @default(true) @map("is_active")
  config      Json     @default("{}")
  conditions  Json?
  sortOrder   Int      @default(0) @map("sort_order")
  parentId    String?  @map("parent_id")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  module      Module     @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  parent      Component? @relation("ComponentTree", fields: [parentId], references: [id])
  children    Component[] @relation("ComponentTree")

  @@unique([moduleId, slug])
  @@map("components")
}

// ═══════════════════════════════════════════════════════════
// Users & Auth
// ═══════════════════════════════════════════════════════════

enum UserRole {
  SUPER_ADMIN
  ADMIN
  MANAGER
  CUSTOMER
}

model User {
  id            String    @id @default(uuid())
  email         String    @unique
  password      String
  name          String
  phone         String?
  role          UserRole  @default(CUSTOMER)
  isActive      Boolean   @default(true) @map("is_active")
  isBlocked     Boolean   @default(false) @map("is_blocked")
  walletBalance Decimal   @default(0) @map("wallet_balance") @db.Decimal(12, 2)
  discountLevel Int       @default(0) @map("discount_level")
  metadata      Json?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  orders        Order[]
  cartItems     CartItem[]
  reviews       Review[]
  chatMessages  ChatMessage[]

  @@map("users")
}

// ═══════════════════════════════════════════════════════════
// Products
// ═══════════════════════════════════════════════════════════

model Category {
  id          String     @id @default(uuid())
  slug        String     @unique
  name        Json
  description Json?
  image       String?
  parentId    String?    @map("parent_id")
  isActive    Boolean    @default(true) @map("is_active")
  sortOrder   Int        @default(0) @map("sort_order")
  showInHeader Boolean   @default(false) @map("show_in_header")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  parent      Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[] @relation("CategoryTree")
  products    Product[]

  @@map("categories")
}

model Product {
  id            String    @id @default(uuid())
  slug          String    @unique
  name          Json
  description   Json?
  price         Decimal   @db.Decimal(12, 2)
  comparePrice  Decimal?  @map("compare_price") @db.Decimal(12, 2)
  stock         Int       @default(0)
  sku           String?
  images        Json      @default("[]")
  isActive      Boolean   @default(true) @map("is_active")
  isFeatured    Boolean   @default(false) @map("is_featured")
  categoryId    String?   @map("category_id")
  dynamicFields Json      @default("{}") @map("dynamic_fields")
  metadata      Json?
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  category      Category?   @relation(fields: [categoryId], references: [id])
  orderItems    OrderItem[]
  cartItems     CartItem[]
  reviews       Review[]

  @@index([categoryId])
  @@index([isActive, isFeatured])
  @@map("products")
}

model ProductFieldDefinition {
  id          String   @id @default(uuid())
  key         String   @unique
  label       Json
  type        String   @default("text")
  options     Json?
  isActive    Boolean  @default(true) @map("is_active")
  showIn      Json     @default("[]") @map("show_in")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("product_field_definitions")
}

// ═══════════════════════════════════════════════════════════
// Orders & Cart
// ═══════════════════════════════════════════════════════════

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model Order {
  id              String      @id @default(uuid())
  orderNumber     String      @unique @map("order_number")
  userId          String      @map("user_id")
  status          OrderStatus @default(PENDING)
  subtotal        Decimal     @db.Decimal(12, 2)
  shippingCost    Decimal     @default(0) @map("shipping_cost") @db.Decimal(12, 2)
  discount        Decimal     @default(0) @db.Decimal(12, 2)
  tax             Decimal     @default(0) @db.Decimal(12, 2)
  total           Decimal     @db.Decimal(12, 2)
  shippingAddress Json        @map("shipping_address")
  paymentMethod   String?     @map("payment_method")
  paymentRef      String?     @map("payment_ref")
  notes           String?
  metadata        Json?
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  user            User        @relation(fields: [userId], references: [id])
  items           OrderItem[]

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String  @map("order_id")
  productId String  @map("product_id")
  quantity  Int
  price     Decimal @db.Decimal(12, 2)
  options   Json?

  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])

  @@map("order_items")
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  quantity  Int      @default(1)
  options   Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@map("cart_items")
}

// ═══════════════════════════════════════════════════════════
// Business Rules
// ═══════════════════════════════════════════════════════════

model BusinessRule {
  id          String   @id @default(uuid())
  name        String
  description String?
  condition   Json
  action      Json
  isActive    Boolean  @default(true) @map("is_active")
  priority    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("business_rules")
}

// ═══════════════════════════════════════════════════════════
// Navigation
// ═══════════════════════════════════════════════════════════

model NavigationItem {
  id        String   @id @default(uuid())
  label     Json
  url       String
  icon      String?
  parentId  String?  @map("parent_id")
  isActive  Boolean  @default(true) @map("is_active")
  sortOrder Int      @default(0) @map("sort_order")
  target    String   @default("_self")
  conditions Json?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  parent    NavigationItem?  @relation("NavTree", fields: [parentId], references: [id])
  children  NavigationItem[] @relation("NavTree")

  @@map("navigation_items")
}

model RouteConfig {
  id          String   @id @default(uuid())
  path        String   @unique
  targetPath  String?  @map("target_path")
  pageType    String   @map("page_type")
  seoConfig   Json?    @map("seo_config")
  isActive    Boolean  @default(true) @map("is_active")
  redirectTo  String?  @map("redirect_to")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("route_configs")
}

// ═══════════════════════════════════════════════════════════
// Reviews & Chat
// ═══════════════════════════════════════════════════════════

model Review {
  id        String   @id @default(uuid())
  productId String   @map("product_id")
  userId    String   @map("user_id")
  rating    Int
  comment   String?
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@map("reviews")
}

model ChatMessage {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  sessionId String   @map("session_id")
  role      String
  content   String
  metadata  Json?
  createdAt DateTime @default(now()) @map("created_at")

  user      User?    @relation(fields: [userId], references: [id])

  @@index([sessionId])
  @@map("chat_messages")
}

// ═══════════════════════════════════════════════════════════
// Blog & Content
// ═══════════════════════════════════════════════════════════

model BlogPost {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       Json
  content     Json
  excerpt     Json?
  image       String?
  isPublished Boolean  @default(false) @map("is_published")
  seoConfig   Json?    @map("seo_config")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("blog_posts")
}

model Coupon {
  id            String    @id @default(uuid())
  code          String    @unique
  discountType  String    @map("discount_type")
  discountValue Decimal   @map("discount_value") @db.Decimal(12, 2)
  minOrder      Decimal?  @map("min_order") @db.Decimal(12, 2)
  maxUses       Int?      @map("max_uses")
  usedCount     Int       @default(0) @map("used_count")
  isActive      Boolean   @default(true) @map("is_active")
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@map("coupons")
}
